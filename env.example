# Copy to .env and fill in. Used for local dev, Docker Compose, or manual runs.

# Session cookie signing (required in production). Generate: openssl rand -hex 32
SESSION_SECRET=

# Port the app listens on (default 5000)
# PORT=5000

# Optional: only for drizzle-kit (db:push). Not used by the app while storage is in-memory.
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
